# ── MySQL / MariaDB (local Raspberry Pi) ────────────────────────────────────
# Format: mysql://user:password@host:port/database
MYSQL_URL=mysql://root:secret@localhost/ambasense

# ── MongoDB Atlas ────────────────────────────────────────────────────────────
# Obtain from: Atlas → Database → Connect → Drivers → Copy the SRV URI
# Replace <username>, <password>, and <cluster> with your values.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Name of the target Atlas database (created automatically on first write)
MONGO_DB=ambasense

# Name of the target collection (created automatically on first write)
MONGO_COLLECTION=co2data

# ── Sync behaviour ───────────────────────────────────────────────────────────
# How often to poll MySQL for new records (seconds); default 60
POLL_INTERVAL_SECS=60

# Maximum rows transferred per cycle; default 100
BATCH_SIZE=100

# ── Logging ──────────────────────────────────────────────────────────────────
# Levels: error | warn | info | debug | trace
RUST_LOG=gateway=info
